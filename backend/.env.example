# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=              # Service role key (server-side only, never expose to frontend)

# Clerk
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_AUDIENCE=                     # Optional in dev — set in staging/production for JWT aud verification

# App
# When the SPA is on Vercel, set this to the exact site origin (e.g. https://your-project.vercel.app) so CORS allows the browser.
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO
ENVIRONMENT=development             # development | staging | production
APP_VERSION=0.1.0

# EdXP-Users (authorization)
EDXP_AUTHZ_URL=
EDXP_ORG_ID=
EDXP_INTERNAL_JWT_SECRET=
EDXP_SERVICE_NAME=ttg-portal

# Mux Video (course VOD — API token syncs playback IDs; signing keys mint signed JWTs)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=
