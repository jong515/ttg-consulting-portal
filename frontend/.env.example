# Auth:
# - omit or "clerk" — real Clerk (requires VITE_CLERK_PUBLISHABLE_KEY).
# - "mock" — local demo only without Clerk (blocked in production builds).
# - "public" — demo login without Clerk, allowed on Vercel / production (preview sites only).
VITE_AUTH_MODE=

VITE_CLERK_PUBLISHABLE_KEY=
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Vercel: without Clerk, set VITE_AUTH_MODE=public (then redeploy). With Clerk, set VITE_CLERK_PUBLISHABLE_KEY
# and VITE_API_BASE_URL under Project Settings > Environment Variables (Production / Preview). Add *.vercel.app
# URLs in the Clerk dashboard when using Clerk.
