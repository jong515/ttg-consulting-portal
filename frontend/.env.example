# Auth: omit or set to "clerk" for real Clerk (requires VITE_CLERK_PUBLISHABLE_KEY).
# Set to "mock" for a local demo login without Clerk or API (development builds only; blocked in production).
VITE_AUTH_MODE=

VITE_CLERK_PUBLISHABLE_KEY=
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Vercel: set VITE_CLERK_PUBLISHABLE_KEY and VITE_API_BASE_URL under Project Settings > Environment Variables
# (Production / Preview). In the Clerk dashboard, add your *.vercel.app URLs to allowed origins and redirect URLs.
