{
  "name": "ttg-consulting-portal-root",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm run dev --prefix frontend\" \"npm run dev:backend\"",
    "dev:backend": "run-script-os",
    "dev:backend:win32": "cd backend && .venv\\Scripts\\python.exe -m uvicorn app.main:app --reload",
    "dev:backend:default": "cd backend && .venv/bin/python -m uvicorn app.main:app --reload"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "run-script-os": "^1.1.6"
  }
}
